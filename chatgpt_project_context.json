      "imageio>=2.34.0",
      "imageio-ffmpeg>=0.5.1",
      "streamlit>=1.38.0",
      "torch>=2.0.0",
      "transformers>=4.30.0",
      "safetensors>=0.4.0"
    ],
    "external_tools": [
      "ffmpeg (needed for audio mux in video pipeline)"
    ]
  },
  "providers_and_models": {
