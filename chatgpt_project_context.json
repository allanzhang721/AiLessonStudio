{
  "document_type": "project_knowledge_pack",
  "intended_use": "Feed into ChatGPT as full project context for writing, analysis, implementation support, debugging, and paper drafting",
  "project": {
    "name": "VisualLesson AI",
    "workspace_root": "/Users/allanzhang/Desktop/AiLessonStudio",
    "project_nature": [
      "research",
      "industrial_prototype"
    ],
    "one_sentence_summary": "Transforms classroom questions into explanation, storyboard plan, educational frames, and narrated videos with checker-gated quality control.",
    "key_value_proposition": [
      "End-to-end educational content generation from a single question",
      "Quality-gated pipeline using Checker 1 (text) and Checker 2 (frames)",
      "Deployable Streamlit app with downloadable artifacts",
      "Multi-provider backend support for text and image generation"
    ],
    "last_known_date": "2026-04-19"
  },
  "goals_and_motivation": {
    "problem_statement": "Teachers and students need fast, classroom-ready visual explanations, but raw LLM/image generation can be pedagogically inconsistent and visually unreliable.",
    "design_goals": [
      "Generate grade-appropriate explanations",
      "Convert explanations into a constrained 7-step visual lesson",
      "Render coherent frame progression suitable for narration",
      "Provide quality control before final output delivery",
      "Support practical product workflows (UI, artifacts, downloads, demo mode)"
    ],
    "non_goals": [
      "Perfect factual verification against external knowledge bases",
      "Full autonomous grading of student answers",
      "Domain-universal guarantees without human review"
    ]
  },
  "high_level_architecture": {
    "pipeline_paths": [
      {
        "name": "Storyboard Path",
        "flow": [
          "Question + Subject + Grade",
          "Explanation Generation",
          "Checker 1 (DistilBERT quality gate)",
          "Plan Generation (7-step JSON)",
          "Frame Generation/Edit",
          "Checker 2 (frame quality gate)",
          "GIF + MP4 assembly"
        ]
      },
      {
        "name": "Single API Video Path",
        "flow": [
          "Reuse storyboard run artifacts",
          "Generate continuous single-video clip (provider-dependent)",
          "Caption/voiceover post-processing"
        ]
      }
    ],
    "system_principles": [
      "Generation and validation are separated",
      "Intermediate artifacts are explicit and persisted",
      "Failures should be observable via manifests",
      "Provider abstraction decouples orchestration from vendor specifics"
    ]
  },
  "repository_map": {
    "entrypoints": [
      {
        "path": "streamlit_app.py",
        "role": "Web UI and user workflow orchestration"
      },
      {
        "path": "pipeline/pipeline.py",
        "role": "Core end-to-end storyboard orchestrator"
      },
      {
        "path": "single_api_video.py",
        "role": "Single API video generation and post-processing"
      },
      {
        "path": "run_demo.py",
        "role": "CLI demo runner"
      }
    ],
    "core_modules": [
      {
        "path": "pipeline/checker.py",
        "role": "Checker 1: DistilBERT error-type classifier and repair loop"
      },
      {
        "path": "pipeline/frame_checker.py",
        "role": "Checker 2: frame quality validator (heuristic now, trainable interface)"
      },
      {
        "path": "pipeline/planner.py",
        "role": "Question/explanation to 7-step plan"
      },
      {
        "path": "pipeline/image_pipeline.py",
        "role": "Plan to 7 frame images"
      },
      {
        "path": "pipeline/video_pipeline.py",
        "role": "Frames plus audio to final video"
      },
      {
        "path": "pipeline/validation.py",
        "role": "Schema, specificity, and relevance validation gates"
      },
      {
        "path": "pipeline/clients.py",
        "role": "Provider client factory and text chat helper"
      },
      {
        "path": "pipeline/config.py",
        "role": "Global constants, model IDs, dimensions, defaults"
      },
      {
        "path": "pipeline/utils.py",
        "role": "Common helpers (I/O, captions, overlays, media)"
      }
    ],
    "tests": [
      "tests/test_validation.py",
      "tests/test_render_failfast.py",
      "tests/test_frame_checker.py"
    ],
    "data_and_models": [
      "checker1/data/*",
      "checker1/model/distilbert_error_type_ckpt/checkpoint-360/*",
      "checker1/notebooks/*"
    ]
  },
  "runtime_and_dependencies": {
    "python": {
      "known_env": "conda research",
      "known_version": "3.12.13"
