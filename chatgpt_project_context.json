  "quality_and_validation": {
    "schema_validation": {
      "module": "pipeline/validation.py",
      "enforces": [
        "top-level plan keys",
        "step schema and sequence",
        "caption completeness",
        "math element coordinate consistency"
      ]
    },
    "specificity_gate": {
      "target": "renderability and concrete instructions",
      "checks": [
        "instruction length",
        "positional constraints",
        "visual attributes",
        "arrow direction semantics",
        "one-new-element discipline",
        "vague phrase penalties"
      ]
    },
    "relevance_gate": {
      "target": "topic adherence",
      "checks": [
        "keyword overlap with question/explanation",
        "off-topic leakage (including coding-term leakage when not applicable)"
      ]
    }
  },
