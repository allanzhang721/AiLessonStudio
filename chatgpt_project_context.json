  "configuration_constants": {
    "canvas": {
      "width": 1536,
      "height": 1024,
      "min_bottom_band": 320,
      "notes": "Bottom caption region reserved; core diagram should stay above caption band"
    },
    "pipeline_defaults": {
      "default_steps": 7,
      "default_output_root": "l15_output"
    },
    "checker1": {
      "checkpoint_dir": "checker1/model/distilbert_error_type_ckpt/checkpoint-360",
      "max_len": 256,
      "labels": [
        "ConceptError",
        "GradeMismatch",
        "LogicalGap",
        "MisleadingAnalogy",
        "MissingCondition"
      ]
    },
    "checker2": {
      "default_backend": "heuristic",
      "default_threshold": 0.58,
      "supported_backends": [
        "heuristic",
        "trained"
      ]
    }
  },
  "input_output_contracts": {
    "primary_input": {
      "question": "string",
      "subject": "string",
      "grade": "int (typically 7-12)",
      "language": "string",
      "text_provider": "openai|deepseek",
      "image_provider": "openai|wanx"
    },
    "plan_schema": {
      "required_top_keys": [
        "question_id",
        "question_text",
        "canonical_answer",
        "visual_family",
        "render_mode",
        "scene_bible",
        "steps",
        "captions",
        "math_elements"
      ],
      "step_count": 7,
      "step_fields": [
        "step_id",
        "goal",
        "delta",
        "forbidden",
        "keep",
        "add"
      ],
      "caption_count": 7
    },
    "pipeline_return_shape": {
      "plan": "dict",
      "out_dir": "path",
      "frames": "list[path]",
      "gif_path": "path",
      "video_path": "path",
      "voiceover_path": "path|null",
      "used_openai": "bool",
      "text_provider": "string",
      "image_provider": "string",
      "checker_result": "dict|null",
      "checker2_result": "dict|null",
      "manifest_path": "path",
      "stage_times": "dict",
      "total_seconds": "float"
    }
  },
  "stage_details": {
    "stage_0_checker1": {
      "module": "pipeline/checker.py",
      "purpose": "Classify explanation error type and optionally repair via LLM loop",
      "model_type": "DistilBERT sequence classifier (5-class)",
      "input_format": "Subject line optional + Grade + Question + Explanation",
      "decision_rule": {
        "confidence_threshold": 0.5,
        "logic": "if confidence >= threshold then revise via GPT and re-check; else accept",
        "max_rounds": 3
      },
      "output_fields": [
        "final_explanation",
        "rounds",
        "was_revised",
        "total_rounds"
      ]
    },
    "stage_A_planner": {
      "module": "pipeline/planner.py",
      "purpose": "Generate structured 7-step educational storyboard plan",
      "strategy": [
        "Try LLM-generated plan",
        "Normalize and validate schema",
        "Apply specificity and relevance gates",
        "Issue refinement prompts when needed",
        "Fallback to deterministic template if necessary"
      ],
      "quality_gates": {
        "specificity_threshold": 0.62,
        "relevance_threshold": 0.45,
        "hard_checks": [
          "schema validity",
          "step/caption count",
          "arrow direction ambiguity checks (optional hard enforcement)"
        ]
      }
    },
    "stage_B_images": {
      "module": "pipeline/image_pipeline.py",
      "purpose": "Render 7 frames from plan with continuity",
      "step_logic": {
        "step_1": "images.generate",
        "steps_2_7": "images.edit on previous raw frame"
      },
      "post_processing": [
        "overlay math elements",
        "append caption band",
        "save raw and final versions"
      ],
      "retry_policy": "Up to 3 attempts with backoff for image API calls"
    },
    "stage_B2_checker2": {
      "module": "pipeline/frame_checker.py",
      "purpose": "Validate quality of rendered frames before final media assembly",
      "current_backend": "heuristic",
      "heuristic_metrics": [
        "resolution",
        "exposure balance (gray mean)",
        "contrast (gray std)",
        "edge detail proxy (edge std)",
        "caption-band readability (caption band std)"
      ],
      "scoring": {
        "formula": "weighted score over 5 subscores",
        "weights": {
          "resolution": 0.2,
          "exposure": 0.2,
          "contrast": 0.25,
          "edge_detail": 0.25,
          "caption_readability": 0.1
        },
        "overall_pass_condition": "avg score >= threshold and no failed steps"
      },
      "issue_tags": [
        "low_resolution",
        "poor_exposure",
        "low_contrast",
        "blurry_or_low_detail",
        "caption_band_low_readability"
      ],
      "trained_backend_status": "interface exists as placeholder; not implemented yet",
      "trained_extension_function": "_validate_with_trained_model"
    },
    "stage_C_video": {
      "module": "pipeline/video_pipeline.py",
      "purpose": "Build GIF/MP4 with optional voiceover",
      "flow": [
        "make GIF",
        "build narration script from captions",
        "synthesize TTS when available",
        "assemble MP4 from frames",
        "mux audio if present"
      ],
      "fps_behavior": "1.0 default; dynamic estimate when voiceover exists"
    }
  },
  "checker2_implementation_notes": {
    "why_added": "Project needed a second checker to validate frame quality beyond text quality",
    "where_integrated": [
      "pipeline/pipeline.py: run_pipeline now executes checker2_validate_frames",
      "pipeline/__init__.py: exports checker2_validate_frames",
      "streamlit_app.py: stores checker2_result and renders it in Details tab",
      "run_manifest.json: now includes checker2_result"
    ],
    "new_run_pipeline_args": [
      {
        "name": "run_checker2",
        "type": "bool",
        "default": true
      },
      {
        "name": "checker2_threshold",
        "type": "float",
        "default": 0.58
      },
      {
        "name": "checker2_backend",
        "type": "string",
        "default": "heuristic"
      }
    ],
    "stage_time_metric": "checker2_seconds",
    "ui_behavior": {
      "during_generation": "status line shows checker2 score/threshold or error",
      "details_tab": "shows overall pass/fail + per-step score/issues"
    }
  },
